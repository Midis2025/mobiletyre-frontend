# Strapi API Base URL
# This should point to your Strapi instance
# Example: https://your-strapi-domain.com/api
# Or for local development: http://localhost:1337/api
VITE_STRAPI_API_URL=https://enduring-morning-cf86e59201.strapiapp.com/api

# Note: The appointment submission endpoint will be:
# POST /api/appointments (collection type: "appointment")


